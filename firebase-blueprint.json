{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the CyberGuard application.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["ADMIN", "EMPLOYEE", "IT_PROVIDER", "VIEWER"] },
        "avatar": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "isNis2Relevant": { "type": "boolean" },
        "coaching": {
          "type": "object",
          "properties": {
            "isActive": { "type": "boolean" },
            "streakDays": { "type": "number" },
            "lastInteraction": { "type": "string", "format": "date-time" },
            "notificationsEnabled": { "type": "boolean" }
          }
        }
      },
      "required": ["id", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A compliance or security task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["TODO", "IN_PROGRESS", "DONE", "NOT_APPLICABLE"] },
        "category": { "type": "string" },
        "framework": { "type": "string" },
        "impact": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "explanation": { "type": "string" },
        "source": { "type": "string" },
        "assigneeId": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "status", "category", "framework", "impact"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Stores all tasks for the application."
    }
  }
}

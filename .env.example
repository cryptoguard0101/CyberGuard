# KMU CyberGuard Environment Variables

# SMTP Configuration for Email Verification
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="KMU CyberGuard" <noreply@example.com>

# Security & HTTPS
FORCE_HTTPS=true
# Auto-generate self-signed certificates if no paths are provided
AUTO_SSL=true
# Optional: Native SSL (leave empty if using reverse proxy like Nginx/Cloud Run)
SSL_KEY_PATH=
SSL_CERT_PATH=

# Gemini API Key (Injected by platform)
# API_KEY=
